{# Nested #}

{% for vhost in vhosts %}
server {
   {% if vhost.port == 80 %}
   listen 80 default_server;
   {% else %}
   listen {{ vhost.port }}
   {% endif %}

   {{ vhost.name }}
}
{% endfor %}

